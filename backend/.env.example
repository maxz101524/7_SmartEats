# SmartEats Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Django secret key - generate a new one for production
# You can generate one at: https://djecrety.ir/
SECRET_KEY=your-secret-key-here

# Add any API keys below
# NUTRITION_API_KEY=your-api-key-here

# Semantic search model routing
# Set to "true" locally to use sentence-transformers directly (requires ~400MB RAM)
# Leave unset or "false" on Render — routes to HuggingFace Inference API instead
USE_LOCAL_MODEL=true

# Optional: HuggingFace API token for higher rate limits on the Inference API
# Free account at huggingface.co — without this, requests are still free but rate-limited
# HF_API_TOKEN=hf_your_token_here
